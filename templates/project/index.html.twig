{% extends 'base.html.twig' %}

{% block title %}Projets{% endblock %}

{% block main %}
<div class="container py-4">

  {# En-tête #}
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Projets de crowdfunding</h1>
    <span class="text-muted small">{{ projects|length }} projet(s)</span>
  </div>

  {% if projects is empty %}
    <div class="alert alert-info">
      Aucun projet n’est disponible pour le moment.
    </div>
  {% else %}
    <div class="row g-4">
      {% for p in projects %}
        {% set percent = p.goalAmount > 0 ? (p.currentAmount / p.goalAmount * 100)|round(0, 'floor') : 0 %}

        <div class="col-12 col-md-6 col-lg-4">
          <div class="card h-100 shadow-sm">

            <div class="card-body d-flex flex-column">
              {# Titre + statut #}
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h5 class="card-title mb-0">{{ p.title }}</h5>
                {% if p.status == 'closed' %}
                  <span class="badge bg-danger">Clôturé</span>
                {% else %}
                  <span class="badge bg-success">Actif</span>
                {% endif %}
              </div>

              {# Description courte #}
              <p class="card-text text-muted mt-2">
                {{ p.description|striptags|slice(0, 120) }}
                {% if p.description|length > 120 %}…{% endif %}
              </p>

              {# Progression #}
              <div class="mt-auto">
                <div class="small text-muted mb-1">
                  {{ p.currentAmount }} / {{ p.goalAmount }}
                </div>

                <div class="progress mb-3" style="height: 8px;">
                  <div class="progress-bar
                    {% if percent >= 100 %}bg-success{% endif %}"
                       style="width: {{ percent > 100 ? 100 : percent }}%;">
                  </div>
                </div>

                <div class="d-flex justify-content-between align-items-center">
                  <span class="small text-muted">{{ percent }}%</span>
                  <a class="btn btn-outline-primary btn-sm"
                     href="{{ path('project_show', {id: p.id}) }}">
                    Voir
                  </a>
                </div>
              </div>
            </div>

          </div>
        </div>
      {% endfor %}
    </div>
  {% endif %}
</div>
{% endblock %}
