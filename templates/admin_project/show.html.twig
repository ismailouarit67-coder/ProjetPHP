{% extends 'base.html.twig' %}

{% block title %}Admin - Détails projet{% endblock %}

{% block main %}
<div class="container py-4" style="max-width: 900px;">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="h4 mb-1">Détails du projet</h1>
      <div class="text-muted small">ID #{{ project.id }}</div>
    </div>

    <div class="d-flex gap-2">
      <a class="btn btn-outline-secondary" href="{{ path('app_admin_project_index') }}">← Liste</a>
      <a class="btn btn-outline-primary" href="{{ path('app_admin_project_edit', {'id': project.id}) }}">Éditer</a>
    </div>
  </div>

  {% set percent = project.goalAmount > 0 ? (project.currentAmount / project.goalAmount * 100)|round(0, 'floor') : 0 %}

  <div class="card shadow-sm mb-3">
    <div class="card-body p-4">

      <div class="d-flex justify-content-between align-items-start gap-3">
        <div>
          <div class="fw-semibold fs-5">{{ project.title }}</div>
          <div class="text-muted small mt-1">
            Fin : <strong>{{ project.endDate ? project.endDate|date('Y-m-d') : '-' }}</strong>
            • Créé : <strong>{{ project.createdAt ? project.createdAt|date('Y-m-d') : '-' }}</strong>
          </div>
        </div>

        {% if project.status == 'closed' %}
          <span class="badge bg-danger">Clôturé</span>
        {% else %}
          <span class="badge bg-success">Actif</span>
        {% endif %}
      </div>

      <p class="text-muted mt-3 mb-0">{{ project.description }}</p>

      <hr class="my-4">

      <div class="row g-3">
        <div class="col-6 col-md-4">
          <div class="p-3 bg-light rounded-3">
            <div class="small text-muted">Objectif</div>
            <div class="fw-bold">{{ project.goalAmount }}</div>
          </div>
        </div>
        <div class="col-6 col-md-4">
          <div class="p-3 bg-light rounded-3">
            <div class="small text-muted">Collecté</div>
            <div class="fw-bold">{{ project.currentAmount }}</div>
          </div>
        </div>
        <div class="col-12 col-md-4">
          <div class="p-3 bg-light rounded-3">
            <div class="small text-muted">Progression</div>
            <div class="fw-bold">{{ percent }}%</div>
          </div>
        </div>
      </div>

      <div class="mt-4">
        <div class="d-flex justify-content-between small text-muted mb-1">
          <span>{{ project.currentAmount }} / {{ project.goalAmount }}</span>
          <span>{{ percent }}%</span>
        </div>

        <div class="progress" style="height: 10px;">
          <div class="progress-bar {% if percent >= 100 %}bg-success{% endif %}"
               style="width: {{ percent > 100 ? 100 : percent }}%;">
          </div>
        </div>
      </div>

    </div>
  </div>

  <div class="card border-danger">
    <div class="card-body d-flex justify-content-between align-items-center">
      <div>
        <div class="fw-semibold text-danger">Zone dangereuse</div>
        <div class="text-muted small">Supprimer ce projet est irréversible.</div>
      </div>
      {{ include('admin_project/_delete_form.html.twig') }}
    </div>
  </div>

</div>
{% endblock %}
