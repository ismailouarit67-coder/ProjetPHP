{% extends 'base.html.twig' %}

{% block title %}Admin - Modifier projet{% endblock %}

{% block main %}
<div class="container py-4" style="max-width: 900px;">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="h4 mb-1">Modifier le projet</h1>
      <div class="text-muted small">Mettez à jour les informations du projet.</div>
    </div>

    <a class="btn btn-outline-secondary" href="{{ path('app_admin_project_index') }}">
      ← Retour à la liste
    </a>
  </div>

  <div class="card shadow-sm mb-3">
    <div class="card-body p-4">
      {{ include('admin_project/_form.html.twig', { button_label: 'Mettre à jour' }) }}
    </div>
  </div>

  <div class="card border-danger">
    <div class="card-body d-flex justify-content-between align-items-center">
      <div>
        <div class="fw-semibold text-danger">Zone dangereuse</div>
        <div class="text-muted small">Supprimer ce projet est irréversible.</div>
      </div>
      {{ include('admin_project/_delete_form.html.twig') }}
    </div>
  </div>

</div>
{% endblock %}
