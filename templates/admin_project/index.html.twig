{% extends 'base.html.twig' %}

{% block title %}Admin - Projets{% endblock %}

{% block main %}
<div class="container py-4">

  <div class="d-flex justify-content-between align-items-center mb-3">
    <div>
      <h1 class="h4 mb-1">Admin — Projets</h1>
      <div class="text-muted small">Gérer les projets (création, modification, suppression).</div>
    </div>
    <a class="btn btn-primary" href="{{ path('app_admin_project_new') }}">
      + Nouveau projet
    </a>
  </div>

  {% if projects is empty %}
    <div class="alert alert-info mb-0">Aucun projet trouvé.</div>
  {% else %}
    <div class="card shadow-sm">
      <div class="table-responsive">
        <table class="table align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th style="width: 70px;">ID</th>
              <th>Titre</th>
              <th style="width: 110px;">Statut</th>
              <th style="width: 140px;">Objectif</th>
              <th style="width: 140px;">Collecté</th>
              <th style="width: 120px;">Fin</th>
              <th style="width: 110px;">Créé</th>
              <th class="text-end" style="width: 190px;">Actions</th>
            </tr>
          </thead>

          <tbody>
          {% for project in projects %}
            {% set percent = project.goalAmount > 0 ? (project.currentAmount / project.goalAmount * 100)|round(0, 'floor') : 0 %}

            <tr>
              <td class="text-muted">{{ project.id }}</td>

              <td>
                <div class="fw-semibold">{{ project.title }}</div>
                <div class="text-muted small">
                  {{ project.description|striptags|slice(0, 80) }}{% if project.description|length > 80 %}…{% endif %}
                </div>

                <div class="progress mt-2" style="height: 6px; max-width: 240px;">
                  <div class="progress-bar {% if percent >= 100 %}bg-success{% endif %}"
                       style="width: {{ percent > 100 ? 100 : percent }}%;">
                  </div>
                </div>
                <div class="small text-muted mt-1">{{ percent }}%</div>
              </td>

              <td>
                {% if project.status == 'closed' %}
                  <span class="badge bg-danger">Clôturé</span>
                {% else %}
                  <span class="badge bg-success">Actif</span>
                {% endif %}
              </td>

              <td>{{ project.goalAmount }}</td>
              <td>{{ project.currentAmount }}</td>

              <td class="text-muted">
                {{ project.endDate ? project.endDate|date('Y-m-d') : '-' }}
              </td>

              <td class="text-muted">
                {{ project.createdAt ? project.createdAt|date('Y-m-d') : '-' }}
              </td>

              <td class="text-end">
                <a class="btn btn-sm btn-outline-secondary"
                   href="{{ path('app_admin_project_show', {'id': project.id}) }}">
                  Voir
                </a>
                <a class="btn btn-sm btn-outline-primary"
                   href="{{ path('app_admin_project_edit', {'id': project.id}) }}">
                  Éditer
                </a>
              </td>
            </tr>
          {% endfor %}
          </tbody>
        </table>
      </div>
    </div>
  {% endif %}

</div>
{% endblock %}
